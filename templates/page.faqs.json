      "settings": {
        "custom_liquid": "<style>\n.custom-help-section {\n  text-align: center;\n  margin: 40px 0;\n  color:#282828\n}\n\n.custom-help-title {\n  font-size: 22px;\n  margin-bottom: 20px;\n  font-weight: 600;\n}\n\n.custom-buttons-wrapper {\n  display: flex;\n  justify-content: center;\n  gap: 16px;\n  flex-wrap: wrap;\n}\n\n.custom-button {\n  border: 2px solid #ff6400;\n  color: #ff6400;\n  text-decoration: none;\n  padding: 14px 28px;\n  font-weight: 600;\n  border-radius: 8px;\n  background: transparent;\n  transition: all 0.3s ease;\n  display: inline-block;\n}\n\n.custom-button:hover {\n  background-color: #ff6400;\n  color: #ffffff;\n}\n</style>\n\n<div class=\"custom-help-section\">\n  <div class=\"custom-help-title\">\n    ¿En qué te podemos ayudar?\n  </div>\n\n  <div class=\"custom-buttons-wrapper\">\n    <a href=\"/pages/lien-1\" class=\"custom-button\">\n      Comprar libros\n    </a>\n\n    <a href=\"/pages/lien-2\" class=\"custom-button\">\n      Vender mis libros\n    </a>\n\n    <a href=\"/pages/lien-3\" class=\"custom-button\">\n      Donar mis libros \n    </a>\n  </div>\n</div>",
