      "default": 14
    },
    {
      "type": "select",
      "id": "label_font_weight",
      "label": "Peso de fuente",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Selectores"
    },
    {
      "type": "range",
      "id": "select_font_size",
      "label": "Tamaño de fuente",
