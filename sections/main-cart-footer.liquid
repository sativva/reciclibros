<style>
    /* --- Resumen carrito Reciclibros (página /cart) --- */
    #main-cart-footer .rl-cart-shipping {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        margin-bottom: 12px;
        background: #e8f1eb;
        border-radius: 8px;
        color: #006837;
        font-weight: 700;
        font-size: 14px;
        line-height: 1.2;
    }
    #main-cart-footer .rl-cart-shipping__check {
        flex: 0 0 auto;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: #006837;
        position: relative;
    }
    #main-cart-footer .rl-cart-shipping__check::after {
        content: "";
        position: absolute;
        top: 4px;
        left: 6px;
        width: 4px;
        height: 8px;
        border: solid #fff;
        border-width: 0 2px 2px 0;
        transform: rotate(45deg);
    }
    #main-cart-footer .rl-cart-summary {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 12px;
        font-size: 15px;
        color: #333333;
    }
    #main-cart-footer .rl-cart-summary__row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 12px;
    }
    #main-cart-footer .rl-cart-summary__strike {
        color: #999;
        text-decoration: line-through;
        white-space: nowrap;
    }
    #main-cart-footer .rl-cart-summary__row--discount { color: #4f4f4f; }
    #main-cart-footer .rl-cart-summary__discount-amount {
        color: #ff6400;
        font-weight: 700;
        white-space: nowrap;
    }
    #main-cart-footer .rl-cart-summary__total {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 8px;
        padding-top: 10px;
        border-top: 1px solid #dedede;
        font-size: 20px;
        color: #333333;
    }
    #main-cart-footer .rl-cart-summary__total strong { font-weight: 700; }
</style>

<div class="page-width{% if cart == empty %} is-empty{% endif %}" id="main-cart-footer" data-id="{{ section.id }}">
  <div class="container container--medium">
    <div class="cart__footer">
      <div class="cart__footer-left">
        {%- if settings.show_cart_note or 1 -%}
        <ap-elementopen id="mini-ap-cartnote" class="mini-cart__order-note">
            <span class="openable__overlay"></span>
            <label for="cart[note]" class="mini-cart__order-note-title heading heading--xsmall">Add Note</label>
            <textarea is="ap-cartnote" name="note" id="cart[note]" rows="3" ap-ariaowns="order-note-toggle" class="input__field input__field--textarea" placeholder="Add Note"></textarea>
            <button type="button" data-action="close" class="d-none form__submit form__submit--closer button button--secondary">Save</button>
        </ap-elementopen>
        {%- endif -%}
        {% if settings.cart_shipping_enable %}
          <div class="shipping-cart">
            <label for="Cart-note">Get shipping estimates</label>
            {% render "shipping-calculator" %}
          </div>
        {%- endif -%}
        {% if settings.cart_coupon_enable %}
          <div class="coupon-cart">
              <label for="discount">Código de descuento</label>
              <div class="mini-cart__order-note-title" style="text-transform: none;font-weight: normal;font-size: 13px;">* El descuento se calculará y aplicará al finalizar la compra</div>
              <div>
	              <input class="discount_code_input" autocomplete="off" type="text" name="discount" value="" />
              </div>
          </div>
      {% endif %}
        {% for block in section.blocks %}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
            
          {%- endcase -%}
        {% endfor %}

        <div id="cart-errors"></div>
      </div>
      <div class="cart__footer-right">
        <div class="cart__recap">
          <div class="cart__recap-block">

            {%- comment -%} Umbral de envío gratis: alinéalo con el de 'ap-freeshippingbar' {%- endcomment -%}
            {%- assign envio_gratis_desde = 1 -%}

            {%- if cart.total_price >= envio_gratis_desde -%}
              <div class="rl-cart-shipping">
                <span class="rl-cart-shipping__check" aria-hidden="true"></span>
                <span>¡Envío gratis!</span>
              </div>
            {%- endif -%}

            <div class="rl-cart-summary">
              <div class="rl-cart-summary__row">
                <span>{{ cart.item_count }} {% if cart.item_count > 1 %}productos{% else %}producto{% endif %}</span>
                {%- if cart.total_price < cart.original_total_price -%}
                  <s class="rl-cart-summary__strike">{{ cart.original_total_price | money }}</s>
                {%- endif -%}
              </div>

              {%- for discount in cart.cart_level_discount_applications -%}
                <div class="rl-cart-summary__row rl-cart-summary__row--discount">
                  <span>{{ discount.title }}</span>
                  <span class="rl-cart-summary__discount-amount">-{{ discount.total_allocated_amount | money }}</span>
                </div>
              {%- endfor -%}

              <div class="rl-cart-summary__total">
                <span>Total</span>
                <span><strong>{{ cart.total_price | money }}</strong></span>
              </div>
            </div>

            <small class="tax-note caption-large rte">IVA incluido</small>
            
            <button id="bt_checkout" type="submit" class="cart__checkout-button checkout-button button button--primary button--full" name="checkout" >
              Ir al pago
            </button>
          </div>
          {%- if additional_checkout_buttons -%}
            <div class="cart__dynamic-checkout-buttons additional-checkout-buttons">
              {{ content_for_additional_checkout_buttons }}
            </div>
          {%- endif -%}

        </div>
        {% if section.settings.enable_payment_methods %}
          <div class="cart__payment-methods">
            <span class="cart__payment-methods-label text--xsmall text--subdued">{{ section.settings.payment_methods_label }}</span>
            <div class="payment-methods-list--center">
              <img src="{{ section.settings.payment_methods_image | image_url: width: 400 }}" width="auto" height="auto" loading="lazy" >
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('bt_checkout').addEventListener('click', function(event) {
    document.getElementById('form_cart').submit();
    console.log('123');
  });
</script>

{% schema %}
{
  "name": "t:sections.main-cart-footer.name",
  "class": "cart__footer-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "header",
      "content": "Payment methods"
    },
    {
      "type": "checkbox",
      "id": "enable_payment_methods",
      "label": "Enable payment methods",
      "default": true
    },
    {
      "type": "text",
      "id": "payment_methods_label",
      "label": "Payment methods label"
    },
    {
      "type": "image_picker",
      "id": "payment_methods_image",
      "label": "Image"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
